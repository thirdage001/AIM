// (validate-manifest.mjs). The .mjs is regenerated by
// scripts/gen-schema-validator.mjs; this declaration is stable.
export interface AjvErrorObject {
  instancePath: string;
  schemaPath: string;
  keyword: string;
  message?: string;
  params: Record<string, unknown>;
}
export interface ValidateFn {
  (data: unknown): boolean;
  errors?: AjvErrorObject[] | null;
}
export declare const validateManifest: ValidateFn;
export declare const validateDraft: ValidateFn;
