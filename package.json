{
  "name": "aim",
  "version": "1.0.0",
  "private": true,
  "description": "Reference implementation of the AIM (Authored Intent Manifest) 1.0 specification",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "vitest run",
    "test:watch": "vitest",
    "gen:schema": "node scripts/gen-schema-validator.mjs",
    "lint": "eslint .",
    "typecheck": "pnpm -r typecheck"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  },
  "devDependencies": {
    "@aim/core": "workspace:*",
    "@aim/adapter-reference": "workspace:*",
    "@aim/resolve": "workspace:*",
    "@aim/author": "workspace:*",
    "@aim/host-node": "workspace:*",
    "@types/node": "^22.10.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "eslint": "^9.17.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.8"
  }
}
